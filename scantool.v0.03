<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ScanTool v3</title>
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;700&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }
      :root {
        --bg: #0d0d0f;
        --s1: #161619;
        --s2: #1e1e23;
        --s3: #26262d;
        --s4: #2e2e38;
        --b: #38383f;
        --b2: #484850;
        --acc: #e8c547;
        --acc2: #5b8dee;
        --acc3: #5bd47a;
        --tx: #dddde8;
        --tx2: #8888a0;
        --tx3: #55556a;
        --font: "IBM Plex Mono", monospace;
      }
      html,
      body {
        height: 100%;
        overflow: hidden;
        background: var(--bg);
        color: var(--tx);
        font-family: var(--font);
        font-size: 12px;
      }
      #app {
        display: grid;
        grid-template-rows: 42px 1fr;
        grid-template-columns: 52px 1fr 260px;
        height: 100vh;
      }

      /* TOPBAR */
      #topbar {
        grid-column: 1/-1;
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 0 8px;
        background: var(--s1);
        border-bottom: 1px solid var(--b);
      }
      .logo {
        font-family: "Syne", sans-serif;
        font-size: 13px;
        font-weight: 800;
        color: var(--acc);
        letter-spacing: 2px;
        margin-right: 6px;
        white-space: nowrap;
      }
      .logo em {
        color: var(--tx2);
        font-style: normal;
      }
      .sep {
        width: 1px;
        height: 20px;
        background: var(--b);
        margin: 0 2px;
        flex-shrink: 0;
      }
      .tbtn {
        height: 28px;
        padding: 0 9px;
        border: 1px solid var(--b);
        background: var(--s2);
        color: var(--tx);
        font-family: var(--font);
        font-size: 11px;
        cursor: pointer;
        border-radius: 3px;
        transition: all 0.12s;
        white-space: nowrap;
        flex-shrink: 0;
      }
      .tbtn:hover {
        background: var(--s3);
        border-color: var(--acc);
        color: var(--acc);
      }
      .tbtn.pri {
        background: var(--acc);
        color: #000;
        border-color: var(--acc);
        font-weight: 700;
      }
      .tbtn.pri:hover {
        background: #f5d666;
      }
      .tbtn:disabled {
        opacity: 0.35;
        cursor: default;
        pointer-events: none;
      }
      #zoom-display {
        font-size: 11px;
        color: var(--tx2);
        min-width: 42px;
        text-align: center;
      }
      #page-info {
        font-size: 10px;
        color: var(--tx3);
        margin-left: auto;
        white-space: nowrap;
      }

      /* TOOLBAR */
      #toolbar {
        grid-row: 2;
        grid-column: 1;
        background: var(--s1);
        border-right: 1px solid var(--b);
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 5px 0;
        gap: 1px;
        overflow: hidden;
      }
      .tool-btn {
        width: 40px;
        height: 38px;
        border: 1px solid transparent;
        background: transparent;
        border-radius: 4px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--tx2);
        transition: all 0.12s;
        position: relative;
        flex-shrink: 0;
      }
      .tool-btn:hover {
        background: var(--s2);
        color: var(--tx);
        border-color: var(--b);
      }
      .tool-btn.active {
        background: var(--s3);
        color: var(--acc);
        border-color: var(--acc);
      }
      .tool-btn svg {
        width: 17px;
        height: 17px;
        pointer-events: none;
      }
      .tool-sep {
        width: 28px;
        height: 1px;
        background: var(--b);
        margin: 2px 0;
        flex-shrink: 0;
      }
      .tip {
        position: absolute;
        left: 46px;
        top: 50%;
        transform: translateY(-50%);
        background: var(--s4);
        color: var(--tx);
        font-size: 10px;
        padding: 3px 8px;
        border-radius: 3px;
        white-space: nowrap;
        pointer-events: none;
        opacity: 0;
        transition: opacity 0.1s;
        border: 1px solid var(--b);
        z-index: 200;
      }
      .tool-btn:hover .tip {
        opacity: 1;
      }

      /* CANVAS */
      #canvas-wrap {
        grid-row: 2;
        grid-column: 2;
        overflow: hidden;
        position: relative;
        background: #080809;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.018) 1px, transparent 1px),
          linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.018) 1px,
            transparent 1px
          );
        background-size: 20px 20px;
        cursor: crosshair;
      }
      #canvas-container {
        position: absolute;
        top: 0;
        left: 0;
        transform-origin: 0 0;
      }
      #display-canvas {
        display: block;
        image-rendering: pixelated;
      }
      #cursor-canvas {
        position: absolute;
        top: 0;
        left: 0;
        pointer-events: none;
        image-rendering: pixelated;
      }
      #canvas-wrap.drag-over {
        outline: 2px dashed var(--acc);
        outline-offset: -4px;
      }
      #drop-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        pointer-events: none;
      }
      #drop-overlay .di {
        font-size: 52px;
        opacity: 0.15;
      }
      #drop-overlay h2 {
        font-family: "Syne", sans-serif;
        font-size: 16px;
        color: var(--tx);
        opacity: 0.3;
      }
      #drop-overlay p {
        font-size: 10px;
        color: var(--tx3);
        text-align: center;
        line-height: 2;
      }
      #drop-overlay.hidden {
        display: none;
      }
      #coords {
        position: absolute;
        bottom: 8px;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(13, 13, 15, 0.88);
        backdrop-filter: blur(6px);
        border: 1px solid var(--b);
        border-radius: 20px;
        padding: 3px 12px;
        font-size: 10px;
        color: var(--tx2);
        pointer-events: none;
        white-space: nowrap;
      }
      /* text input overlay */
      #text-input-wrap {
        position: absolute;
        top: 0;
        left: 0;
        pointer-events: none;
        width: 100%;
        height: 100%;
        overflow: hidden;
      }
      .text-ta {
        position: absolute;
        background: rgba(91, 141, 238, 0.08);
        border: 1.5px dashed rgba(91, 141, 238, 0.6);
        outline: none;
        resize: none;
        overflow: hidden;
        padding: 0;
        margin: 0;
        pointer-events: all;
        color: transparent;
        caret-color: #fff;
        z-index: 50;
        line-height: 1.3;
      }

      /* PANEL */
      #panel {
        grid-row: 2;
        grid-column: 3;
        background: var(--s1);
        border-left: 1px solid var(--b);
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
      #panel-tabs {
        display: flex;
        border-bottom: 1px solid var(--b);
        flex-shrink: 0;
      }
      .ptab {
        flex: 1;
        height: 32px;
        border: none;
        background: transparent;
        color: var(--tx2);
        font-family: var(--font);
        font-size: 10px;
        letter-spacing: 0.5px;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        transition: all 0.12s;
        text-transform: uppercase;
      }
      .ptab:hover {
        color: var(--tx);
      }
      .ptab.active {
        color: var(--acc);
        border-bottom-color: var(--acc);
      }
      .tab-pane {
        display: none;
        flex: 1;
        overflow-y: auto;
        padding: 10px;
        flex-direction: column;
        gap: 8px;
      }
      .tab-pane.active {
        display: flex;
      }
      .slabel {
        font-size: 9px;
        letter-spacing: 2px;
        color: var(--tx3);
        text-transform: uppercase;
        border-bottom: 1px solid var(--b);
        padding-bottom: 4px;
        margin-bottom: 2px;
      }

      /* PROPS */
      .prop-row {
        display: flex;
        align-items: center;
        gap: 7px;
        color: var(--tx2);
        font-size: 11px;
      }
      .prop-row span {
        min-width: 24px;
        text-align: right;
        color: var(--tx);
        font-size: 11px;
      }
      input[type="range"] {
        flex: 1;
        height: 3px;
        -webkit-appearance: none;
        appearance: none;
        background: var(--s3);
        border-radius: 2px;
        cursor: pointer;
      }
      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--acc);
        cursor: pointer;
      }
      .shape-grp {
        display: flex;
        gap: 3px;
        flex: 1;
      }
      .tbtn-sm {
        flex: 1;
        height: 25px;
        border: 1px solid var(--b);
        background: var(--s2);
        color: var(--tx2);
        font-family: var(--font);
        font-size: 10px;
        cursor: pointer;
        border-radius: 3px;
        transition: all 0.1s;
      }
      .tbtn-sm.active {
        background: var(--s3);
        border-color: var(--acc);
        color: var(--acc);
      }
      .tbtn-sm:hover {
        border-color: var(--b2);
      }
      input[type="text"],
      select {
        background: var(--s3);
        border: 1px solid var(--b);
        color: var(--tx);
        font-family: var(--font);
        font-size: 11px;
        padding: 3px 6px;
        border-radius: 3px;
        outline: none;
        width: 100%;
      }
      input[type="text"]:focus,
      select:focus {
        border-color: var(--acc);
      }
      select option {
        background: var(--s3);
      }

      /* HSV PICKER */
      #hsv-wrap {
        display: flex;
        gap: 6px;
        align-items: flex-start;
      }
      #sv-canvas {
        border-radius: 3px;
        cursor: crosshair;
        flex-shrink: 0;
      }
      #hue-canvas {
        border-radius: 2px;
        cursor: ns-resize;
        flex-shrink: 0;
      }
      #color-preview {
        width: 28px;
        height: 28px;
        border-radius: 3px;
        border: 1px solid var(--b);
        flex-shrink: 0;
      }
      .swatch-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 3px;
      }
      .swatch {
        width: 100%;
        aspect-ratio: 1;
        border-radius: 2px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: border-color 0.1s;
      }
      .swatch:hover,
      .swatch.active {
        border-color: var(--acc);
      }

      /* LAYERS */
      .layer-wrap {
        display: flex;
        flex-direction: column;
        gap: 2px;
      }
      .layer-row {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 4px 5px;
        border-radius: 4px;
        border: 1px solid transparent;
        cursor: pointer;
        transition: all 0.12s;
        background: var(--s2);
      }
      .layer-row:hover {
        background: var(--s3);
      }
      .layer-row.active-layer {
        background: var(--s3);
        border-color: var(--acc);
      }
      .layer-eye {
        width: 20px;
        height: 20px;
        border: none;
        background: transparent;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 3px;
        flex-shrink: 0;
        padding: 0;
        font-size: 12px;
      }
      .layer-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .layer-name {
        flex: 1;
        font-size: 11px;
        color: var(--tx);
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        min-width: 0;
      }
      .layer-pct {
        font-size: 9px;
        color: var(--tx3);
        white-space: nowrap;
      }
      .layer-acts {
        display: flex;
        gap: 1px;
        flex-shrink: 0;
      }
      .lico {
        width: 19px;
        height: 19px;
        border: none;
        background: transparent;
        cursor: pointer;
        color: var(--tx3);
        font-size: 11px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 2px;
        transition: color 0.1s;
        padding: 0;
      }
      .lico:hover {
        color: var(--tx);
      }
      .lico.del:hover {
        color: #e85b5b;
      }
      .lico:disabled {
        opacity: 0.2;
        cursor: default;
        pointer-events: none;
      }
      .layer-oprow {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 2px 5px 5px;
        font-size: 10px;
        color: var(--tx2);
      }
      .add-layer-btn {
        height: 27px;
        border: 1px dashed var(--b2);
        background: transparent;
        color: var(--tx2);
        font-family: var(--font);
        font-size: 11px;
        cursor: pointer;
        border-radius: 4px;
        transition: all 0.12s;
        margin-top: 3px;
        width: 100%;
      }
      .add-layer-btn:hover {
        border-color: var(--acc);
        color: var(--acc);
      }
      .layer-name-input {
        flex: 1;
        background: var(--s4);
        border: 1px solid var(--acc);
        color: var(--tx);
        font-family: var(--font);
        font-size: 11px;
        padding: 1px 4px;
        border-radius: 2px;
        outline: none;
        min-width: 0;
      }

      /* HISTORY */
      .hist-nav {
        display: flex;
        gap: 4px;
        flex-shrink: 0;
      }
      .hitem {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 4px 7px;
        border-radius: 3px;
        border-left: 2px solid transparent;
        color: var(--tx2);
        font-size: 10px;
      }
      .hitem.cur {
        background: var(--s3);
        border-left-color: var(--acc);
        color: var(--tx);
      }
      .hitem.fut {
        opacity: 0.28;
      }
      .hico {
        font-size: 12px;
        width: 16px;
        text-align: center;
        flex-shrink: 0;
      }
      .hlbl {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }
      .hlyr {
        color: var(--tx3);
        white-space: nowrap;
        font-size: 9px;
      }
      .no-hist {
        font-size: 10px;
        color: var(--tx3);
        text-align: center;
        padding: 16px 0;
      }

      /* TOAST */
      #toast {
        position: fixed;
        bottom: 20px;
        right: 20px;
        background: var(--s4);
        border: 1px solid var(--acc);
        color: var(--acc);
        font-size: 11px;
        padding: 7px 14px;
        border-radius: 4px;
        opacity: 0;
        transform: translateY(6px);
        transition: all 0.18s;
        pointer-events: none;
        z-index: 9999;
      }
      #toast.show {
        opacity: 1;
        transform: translateY(0);
      }
    </style>
  </head>
  <body>
    <div id="app">
      <!-- TOPBAR -->
      <div id="topbar">
        <div class="logo">⬡ SCAN<em>TOOL</em></div>
        <div class="sep"></div>
        <button class="tbtn" onclick="document.getElementById('fi').click()">
          📂 Abrir
        </button>
        <input type="file" id="fi" accept="image/*" style="display: none" />
        <div class="sep"></div>
        <button class="tbtn" id="btn-undo" onclick="undo()" disabled>↩</button>
        <button class="tbtn" id="btn-redo" onclick="redo()" disabled>↪</button>
        <div class="sep"></div>
        <button class="tbtn" onclick="zoomOut()">−</button>
        <div id="zoom-display">100%</div>
        <button class="tbtn" onclick="zoomIn()">+</button>
        <button class="tbtn" onclick="zoomFit()">Fit</button>
        <div class="sep"></div>
        <button class="tbtn" onclick="saveProject()">💾 Guardar</button>
        <button
          class="tbtn"
          onclick="document.getElementById('load-fi').click()"
        >
          📁 Cargar
        </button>
        <input
          type="file"
          id="load-fi"
          accept=".scantool,.json"
          style="display: none"
        />
        <div class="sep"></div>
        <button class="tbtn pri" onclick="exportPNG()">⬇ PNG</button>
        <div id="page-info">Sin imagen</div>
      </div>

      <!-- TOOLBAR -->
      <div id="toolbar">
        <button
          class="tool-btn active"
          id="tb-brush"
          onclick="setTool('brush')"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z" />
            <path
              d="M20.71 7.04a1 1 0 000-1.41l-2.34-2.34a1 1 0 00-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z"
            />
          </svg>
          <span class="tip">Pincel (B)</span>
        </button>
        <button class="tool-btn" id="tb-eraser" onclick="setTool('eraser')">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M20 20H7L3 16l10-10 7 7-3.5 3.5" />
            <path d="M6 10l8 8" />
          </svg>
          <span class="tip">Borrador (E)</span>
        </button>
        <button class="tool-btn" id="tb-fill" onclick="setTool('fill')">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M16.56 8.94L7.62 0 6.21 1.41l2.38 2.38-5.15 5.15a1.49 1.49 0 000 2.12l5.5 5.5c.29.29.68.44 1.06.44s.77-.15 1.06-.44l5.5-5.5c.59-.58.59-1.53 0-2.12zM5.21 10L10 5.21 14.79 10H5.21zM19 11.5s-2 2.17-2 3.5c0 1.1.9 2 2 2s2-.9 2-2c0-1.33-2-3.5-2-3.5z"
            />
          </svg>
          <span class="tip">Relleno (F)</span>
        </button>
        <div class="tool-sep"></div>
        <button class="tool-btn" id="tb-select" onclick="setTool('select')">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-dasharray="3 2"
          >
            <rect x="3" y="3" width="18" height="18" rx="1" />
          </svg>
          <span class="tip">Selección (S)</span>
        </button>
        <button class="tool-btn" id="tb-text" onclick="setTool('text')">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <polyline points="4 7 4 4 20 4 20 7" />
            <line x1="9" y1="20" x2="15" y2="20" />
            <line x1="12" y1="4" x2="12" y2="20" />
          </svg>
          <span class="tip">Texto (T)</span>
        </button>
        <button
          class="tool-btn"
          id="tb-eyedropper"
          onclick="setTool('eyedropper')"
        >
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M20.84 4.61a5.5 5.5 0 00-7.78 0L3 14.67V21h6.33l10.06-10.06a5.5 5.5 0 000-7.78z"
            />
            <line x1="15.5" y1="8.5" x2="9" y2="15" />
          </svg>
          <span class="tip">Cuentagotas (I)</span>
        </button>
        <div class="tool-sep"></div>
        <button class="tool-btn" id="tb-pan" onclick="setTool('pan')">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M5 9l-3 3 3 3M9 5l3-3 3 3M15 19l-3 3-3-3M19 9l3 3-3 3M2 12h20M12 2v20"
            />
          </svg>
          <span class="tip">Mover (V)</span>
        </button>
        <button class="tool-btn" id="tb-zoom" onclick="setTool('zoomtool')">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <circle cx="11" cy="11" r="8" />
            <line x1="21" y1="21" x2="16.65" y2="16.65" />
            <line x1="11" y1="8" x2="11" y2="14" />
            <line x1="8" y1="11" x2="14" y2="11" />
          </svg>
          <span class="tip">Zoom (Z)</span>
        </button>
      </div>

      <!-- CANVAS -->
      <div id="canvas-wrap">
        <div id="canvas-container">
          <canvas id="display-canvas"></canvas>
          <canvas id="cursor-canvas"></canvas>
        </div>
        <div id="text-input-wrap"></div>
        <div id="drop-overlay">
          <div class="di">🖼️</div>
          <h2>Arrastrá una página aquí</h2>
          <p>o usá "Abrir" · JPG · PNG · WEBP</p>
        </div>
        <div id="coords">x: 0 y: 0</div>
      </div>

      <!-- PANEL -->
      <div id="panel">
        <div id="panel-tabs">
          <button class="ptab active" onclick="switchTab('props')">
            Props
          </button>
          <button class="ptab" onclick="switchTab('layers')">Capas</button>
          <button class="ptab" onclick="switchTab('history')">Historial</button>
        </div>
        <div class="tab-pane active" id="tab-props">
          <div id="props-content"></div>
        </div>
        <div class="tab-pane" id="tab-layers">
          <div class="slabel">Capas</div>
          <div id="layers-list"></div>
          <button class="add-layer-btn" onclick="addLayer()">
            + Nueva capa
          </button>
          <div
            style="
              font-size: 9px;
              color: var(--tx3);
              line-height: 1.8;
              margin-top: 5px;
            "
          >
            Doble-click → renombrar · Alt+click → solo esa capa
          </div>
        </div>
        <div class="tab-pane" id="tab-history">
          <div class="slabel">Historial</div>
          <div class="hist-nav" style="margin-bottom: 6px">
            <button
              class="tbtn"
              style="flex: 1"
              id="h-undo"
              onclick="undo()"
              disabled
            >
              ↩ Deshacer
            </button>
            <button
              class="tbtn"
              style="flex: 1"
              id="h-redo"
              onclick="redo()"
              disabled
            >
              ↪ Rehacer
            </button>
          </div>
          <div id="history-list"></div>
        </div>
      </div>
    </div>
    <div id="toast"></div>

    <script>
      // ═══════════════════════════════════════════════════════
      //  CANVAS SETUP  (logical pixels, NO DPR scaling)
      // ═══════════════════════════════════════════════════════
      const displayCanvas = document.getElementById("display-canvas");
      const displayCtx = displayCanvas.getContext("2d", {
        willReadFrequently: true,
      });
      const cursorCanvas = document.getElementById("cursor-canvas");
      const cursorCtx = cursorCanvas.getContext("2d");
      const wrap = document.getElementById("canvas-wrap");
      const container = document.getElementById("canvas-container");
      const textInputWrap = document.getElementById("text-input-wrap");

      displayCtx.imageSmoothingEnabled = false;
      cursorCtx.imageSmoothingEnabled = false;

      // ─ base state ─
      let tool = "brush",
        brushSize = 20,
        brushOpacity = 1,
        brushShape = "round";
      let fillTol = 30,
        color = "#ffffff";
      let zoom = 1,
        panX = 0,
        panY = 0;
      let painting = false,
        spaceDown = false,
        lastX = 0,
        lastY = 0;
      let panSX = 0,
        panSY = 0,
        panOX = 0,
        panOY = 0;
      let imageLoaded = false,
        pendingBefore = null;
      let imgW = 0,
        imgH = 0;
      let lastMouse = { x: 0, y: 0 };

      // ─ selection ─
      let selection = null; // {x,y,w,h}
      let selecting = false,
        selStart = null;
      let marchOffset = 0;

      // ─ text ─
      let textObjects = [],
        selectedTextId = null,
        nextTextId = 1;
      let textDragging = false,
        textDragOffset = { x: 0, y: 0 };
      let activeTA = null; // active textarea element
      let textProps = {
        font: "Arial",
        size: 24,
        color: "#000000",
        useStroke: true,
        strokeColor: "#ffffff",
        strokeWidth: 3,
        bold: false,
      };

      // ─ color picker ─
      let pickerH = 0,
        pickerS = 0,
        pickerV = 1;
      let svDragging = false,
        hueDragging = false;

      // ═══════════════════════════════════════════════════════
      //  LAYERS
      // ═══════════════════════════════════════════════════════
      let layers = [],
        activeLayerIndex = 1,
        nextLayerId = 1;

      function mkLayer(name, dotColor, locked) {
        return {
          id: nextLayerId++,
          name,
          dotColor,
          visible: true,
          locked: !!locked,
          opacity: 1,
          canvas: null,
        };
      }
      function mkLayerCanvas(w, h) {
        const c = document.createElement("canvas");
        c.width = w;
        c.height = h;
        c.getContext("2d", { willReadFrequently: true }).imageSmoothingEnabled =
          false;
        return c;
      }
      function initLayers(w, h) {
        imgW = w;
        imgH = h;
        layers = [
          mkLayer("Original", "#888888", true),
          mkLayer("Limpieza", "#5b8dee"),
          mkLayer("Texto", "#5bd47a"),
        ];
        layers.forEach((l) => {
          l.canvas = mkLayerCanvas(w, h);
        });
        activeLayerIndex = 1;
      }
      function getLayerCtx(i) {
        const ctx = layers[i]?.canvas?.getContext("2d", {
          willReadFrequently: true,
        });
        if (ctx) ctx.imageSmoothingEnabled = false;
        return ctx || null;
      }
      function getActiveCtx() {
        return getLayerCtx(activeLayerIndex);
      }
      function captureLayer(i) {
        const c = layers[i]?.canvas;
        return c
          ? c
              .getContext("2d", { willReadFrequently: true })
              .getImageData(0, 0, c.width, c.height)
          : null;
      }
      function composite() {
        displayCtx.clearRect(0, 0, imgW, imgH);
        displayCtx.imageSmoothingEnabled = false;
        for (const l of layers) {
          if (!l.visible || !l.canvas) continue;
          displayCtx.globalAlpha = l.opacity;
          displayCtx.drawImage(l.canvas, 0, 0);
        }
        displayCtx.globalAlpha = 1;
        drawTextObjects(displayCtx);
      }

      // ═══════════════════════════════════════════════════════
      //  HISTORY
      // ═══════════════════════════════════════════════════════
      const hist = [];
      let histIdx = -1;
      function pushHist(label, icon, layerIndex, before, after) {
        hist.splice(histIdx + 1);
        hist.push({
          label,
          icon,
          layerName: layers[layerIndex]?.name || "",
          layerIndex,
          before,
          after,
        });
        if (hist.length > 40) hist.shift();
        histIdx = hist.length - 1;
        renderHistory();
        updateURBtns();
      }
      function undo() {
        if (histIdx < 0) return;
        const it = hist[histIdx];
        getLayerCtx(it.layerIndex)?.putImageData(it.before, 0, 0);
        histIdx--;
        composite();
        renderHistory();
        updateURBtns();
      }
      function redo() {
        if (histIdx >= hist.length - 1) return;
        histIdx++;
        const it = hist[histIdx];
        getLayerCtx(it.layerIndex)?.putImageData(it.after, 0, 0);
        composite();
        renderHistory();
        updateURBtns();
      }
      function updateURBtns() {
        const u = histIdx >= 0,
          r = histIdx < hist.length - 1;
        ["btn-undo", "h-undo"].forEach(
          (id) => (document.getElementById(id).disabled = !u),
        );
        ["btn-redo", "h-redo"].forEach(
          (id) => (document.getElementById(id).disabled = !r),
        );
      }

      // ═══════════════════════════════════════════════════════
      //  COLOR HELPERS
      // ═══════════════════════════════════════════════════════
      function hexToHSV(hex) {
        let r = parseInt(hex.slice(1, 3), 16) / 255,
          g = parseInt(hex.slice(3, 5), 16) / 255,
          b = parseInt(hex.slice(5, 7), 16) / 255;
        const max = Math.max(r, g, b),
          min = Math.min(r, g, b),
          d = max - min;
        let h = 0,
          s = max === 0 ? 0 : d / max,
          v = max;
        if (d !== 0) {
          if (max === r) h = ((g - b) / d + 6) % 6;
          else if (max === g) h = (b - r) / d + 2;
          else h = (r - g) / d + 4;
          h *= 60;
        }
        return [h, s, v];
      }
      function hsvToHex(h, s, v) {
        const f = (n, k = (n + h / 60) % 6) =>
          v - v * s * Math.max(Math.min(k, 4 - k, 1), 0);
        return (
          "#" +
          [f(5), f(3), f(1)]
            .map((x) =>
              Math.round(x * 255)
                .toString(16)
                .padStart(2, "0"),
            )
            .join("")
        );
      }
      function setColor(hex) {
        color = hex;
        [pickerH, pickerS, pickerV] = hexToHSV(hex);
        refreshPickerUI();
      }

      // ═══════════════════════════════════════════════════════
      //  TOOL
      // ═══════════════════════════════════════════════════════
      function setTool(t) {
        if (activeTA) finalizeTA();
        tool = t;
        document
          .querySelectorAll(".tool-btn")
          .forEach((b) => b.classList.remove("active"));
        const map = {
          brush: "tb-brush",
          eraser: "tb-eraser",
          fill: "tb-fill",
          select: "tb-select",
          text: "tb-text",
          eyedropper: "tb-eyedropper",
          pan: "tb-pan",
          zoomtool: "tb-zoom",
        };
        document.getElementById(map[t])?.classList.add("active");
        wrap.style.cursor =
          t === "pan"
            ? "grab"
            : t === "zoomtool"
              ? "zoom-in"
              : t === "eyedropper"
                ? "crosshair"
                : t === "text"
                  ? "text"
                  : "crosshair";
        if (t !== "select") {
          clearSelection();
        }
        if (t !== "text") {
          selectedTextId = null;
        }
        renderProps();
      }
      function setBrushShape(s) {
        brushShape = s;
        document
          .getElementById("sh-round")
          ?.classList.toggle("active", s === "round");
        document
          .getElementById("sh-sq")
          ?.classList.toggle("active", s === "square");
      }

      // ═══════════════════════════════════════════════════════
      //  PROPS PANEL
      // ═══════════════════════════════════════════════════════
      const SWATCHES = [
        "#ffffff",
        "#000000",
        "#f5f5f0",
        "#e8e0d0",
        "#d4c9b0",
        "#a09080",
        "#3a3a3a",
        "#ffe8c8",
        "#c8e0ff",
        "#ffc8e8",
        "#c8ffd4",
        "#ffd4c8",
        "#d4c8ff",
        "#c8ffe8",
      ];
      const FONTS = [
        "Arial",
        "Arial Black",
        "Georgia",
        "Courier New",
        "Impact",
        "Comic Sans MS",
        "Verdana",
        "Times New Roman",
      ];

      function renderProps() {
        const t = tool;
        let h = "";
        if (t === "brush" || t === "eraser") {
          h += `<div class="slabel">${t === "brush" ? "Pincel" : "Borrador"}</div>
    <div class="prop-row">Tamaño<input type="range" min="1" max="200" value="${brushSize}"
      oninput="brushSize=+this.value;document.getElementById('vs').textContent=this.value"><span id="vs">${brushSize}</span></div>
    <div class="prop-row">Opacidad<input type="range" min="1" max="100" value="${Math.round(brushOpacity * 100)}"
      oninput="brushOpacity=this.value/100;document.getElementById('vo').textContent=this.value"><span id="vo">${Math.round(brushOpacity * 100)}</span></div>
    <div class="prop-row">Forma<div class="shape-grp">
      <button class="tbtn-sm ${brushShape === "round" ? "active" : ""}" id="sh-round" onclick="setBrushShape('round')">● Round</button>
      <button class="tbtn-sm ${brushShape === "square" ? "active" : ""}" id="sh-sq" onclick="setBrushShape('square')">■ Square</button>
    </div></div>`;
        }
        if (t === "fill") {
          h += `<div class="slabel">Relleno</div>
    <div class="prop-row">Tolerancia<input type="range" min="0" max="255" value="${fillTol}"
      oninput="fillTol=+this.value;document.getElementById('vt').textContent=this.value"><span id="vt">${fillTol}</span></div>`;
        }
        if (t === "select") {
          h += `<div class="slabel">Selección</div>
    <div style="font-size:10px;color:var(--tx2);line-height:2">
      Arrastrá para seleccionar.<br>Herramientas respetan la selección.
    </div>
    ${
      selection
        ? `<div style="font-size:10px;color:var(--acc)">▸ ${selection.w} × ${selection.h} px</div>
    <button class="tbtn-sm" style="margin-top:2px" onclick="clearSelection();redrawCursor()">✕ Deseleccionar (Ctrl+D)</button>`
        : '<div style="font-size:10px;color:var(--tx3)">Sin selección activa</div>'
    }`;
        }
        if (t === "text") {
          const sel = textObjects.find((o) => o.id === selectedTextId);
          h += `<div class="slabel">Texto</div>
    <div class="prop-row" style="gap:4px">
      <span style="min-width:34px">Fuente</span>
      <select onchange="textProps.font=this.value;composite()" style="flex:1">
        ${FONTS.map((f) => `<option value="${f}" ${textProps.font === f ? "selected" : ""}>${f}</option>`).join("")}
      </select>
    </div>
    <div class="prop-row">Tamaño<input type="range" min="8" max="120" value="${textProps.size}"
      oninput="textProps.size=+this.value;document.getElementById('vts').textContent=this.value;composite()"><span id="vts">${textProps.size}</span></div>
    <div class="shape-grp">
      <button class="tbtn-sm ${textProps.bold ? "active" : ""}" onclick="textProps.bold=!textProps.bold;this.classList.toggle('active');composite()"><b>B</b></button>
      <button class="tbtn-sm ${textProps.useStroke ? "active" : ""}" onclick="textProps.useStroke=!textProps.useStroke;this.classList.toggle('active');composite()">Borde</button>
    </div>
    <div class="prop-row">Color texto<input type="color" value="${textProps.color}" style="width:36px;height:22px;padding:1px"
      oninput="textProps.color=this.value;composite()"></div>
    ${
      textProps.useStroke
        ? `<div class="prop-row">Color borde<input type="color" value="${textProps.strokeColor}" style="width:36px;height:22px;padding:1px"
      oninput="textProps.strokeColor=this.value;composite()"></div>
    <div class="prop-row">Grosor borde<input type="range" min="1" max="10" value="${textProps.strokeWidth}"
      oninput="textProps.strokeWidth=+this.value;document.getElementById('vsw').textContent=this.value;composite()"><span id="vsw">${textProps.strokeWidth}</span></div>`
        : ""
    }
    ${sel ? `<button class="tbtn-sm" style="margin-top:4px;color:#e85b5b;border-color:#e85b5b" onclick="deleteSelectedText()">✕ Eliminar texto</button>` : ""}
    <div style="font-size:9px;color:var(--tx3);line-height:1.8;margin-top:2px">
      Click = crear · Click texto = mover<br>Doble-click = editar · Delete = eliminar
    </div>`;
        }
        if (t === "eyedropper") {
          h += `<div class="slabel">Cuentagotas</div>
    <div style="font-size:10px;color:var(--tx2);line-height:2">Click en el canvas para tomar un color.<br>Alt+Click funciona con cualquier herramienta.</div>`;
        }
        if (t === "pan")
          h += `<div class="slabel">Mover vista</div><div style="font-size:10px;color:var(--tx2);line-height:2">Arrastrá el canvas.<br>Espacio + arrastrar.</div>`;
        if (t === "zoomtool")
          h += `<div class="slabel">Zoom</div><div style="font-size:10px;color:var(--tx2);line-height:2">Click = acercar<br>Shift+Click = alejar</div>`;

        // Color picker (for brush, eraser, fill, eyedropper result)
        if (["brush", "eraser", "fill", "eyedropper"].includes(t)) {
          h += `<div class="slabel" style="margin-top:4px">Color</div>
    <div id="hsv-wrap">
      <canvas id="sv-canvas" width="140" height="130"></canvas>
      <canvas id="hue-canvas" width="14" height="130"></canvas>
    </div>
    <div style="display:flex;gap:6px;align-items:center;margin-top:5px">
      <div id="color-preview" style="background:${color}"></div>
      <input type="text" id="hex-input" value="${color}" placeholder="#ffffff"
        style="flex:1" oninput="onHexInput(this.value)">
    </div>
    <div class="swatch-grid" style="margin-top:5px">
      ${SWATCHES.map((c) => `<div class="swatch${color === c ? " active" : ""}" style="background:${c}" data-c="${c}" onclick="setColor('${c}');refreshPickerUI()"></div>`).join("")}
    </div>`;
        }

        h += `<div class="slabel" style="margin-top:4px">Atajos</div>
  <div style="font-size:10px;color:var(--tx2);line-height:2.1">
    <b style="color:var(--tx)">B E F S T I V Z</b> — tools<br>
    <b style="color:var(--tx)">[ ]</b> — tamaño pincel<br>
    <b style="color:var(--tx)">Ctrl+Z/Y</b> — deshacer/rehacer<br>
    <b style="color:var(--tx)">Ctrl+D</b> — deseleccionar<br>
    <b style="color:var(--tx)">Alt+Click</b> — cuentagotas<br>
    <b style="color:var(--tx)">Delete</b> — eliminar texto selec.
  </div>`;

        document.getElementById("props-content").innerHTML = h;
        initPickerCanvases();
      }

      function onHexInput(v) {
        if (/^#[0-9a-fA-F]{6}$/.test(v)) setColor(v);
      }

      // ═══════════════════════════════════════════════════════
      //  HSV COLOR PICKER
      // ═══════════════════════════════════════════════════════
      function initPickerCanvases() {
        const sv = document.getElementById("sv-canvas");
        const hue = document.getElementById("hue-canvas");
        if (!sv || !hue) return;
        drawSVCanvas(sv);
        drawHueCanvas(hue);

        // SV interactions
        function onSV(e) {
          const r = sv.getBoundingClientRect();
          pickerS = Math.max(0, Math.min(1, (e.clientX - r.left) / sv.width));
          pickerV = Math.max(
            0,
            Math.min(1, 1 - (e.clientY - r.top) / sv.height),
          );
          color = hsvToHex(pickerH, pickerS, pickerV);
          refreshPickerUI();
          drawSVCanvas(sv);
        }
        sv.addEventListener("mousedown", (e) => {
          svDragging = true;
          onSV(e);
        });
        sv.addEventListener("mousemove", (e) => {
          if (svDragging) onSV(e);
        });

        // Hue bar interactions
        function onHue(e) {
          const r = hue.getBoundingClientRect();
          pickerH = Math.max(
            0,
            Math.min(360, ((e.clientY - r.top) / hue.height) * 360),
          );
          color = hsvToHex(pickerH, pickerS, pickerV);
          refreshPickerUI();
          drawSVCanvas(sv);
          drawHueCanvas(hue);
        }
        hue.addEventListener("mousedown", (e) => {
          hueDragging = true;
          onHue(e);
        });
        hue.addEventListener("mousemove", (e) => {
          if (hueDragging) onHue(e);
        });
      }

      document.addEventListener("mouseup", () => {
        svDragging = false;
        hueDragging = false;
      });

      function drawSVCanvas(c) {
        if (!c) return;
        const ctx = c.getContext("2d"),
          w = c.width,
          h = c.height;
        ctx.fillStyle = `hsl(${pickerH},100%,50%)`;
        ctx.fillRect(0, 0, w, h);
        const wg = ctx.createLinearGradient(0, 0, w, 0);
        wg.addColorStop(0, "rgba(255,255,255,1)");
        wg.addColorStop(1, "rgba(255,255,255,0)");
        ctx.fillStyle = wg;
        ctx.fillRect(0, 0, w, h);
        const bg = ctx.createLinearGradient(0, 0, 0, h);
        bg.addColorStop(0, "rgba(0,0,0,0)");
        bg.addColorStop(1, "rgba(0,0,0,1)");
        ctx.fillStyle = bg;
        ctx.fillRect(0, 0, w, h);
        // cursor
        const cx = pickerS * w,
          cy = (1 - pickerV) * h;
        ctx.strokeStyle = "white";
        ctx.lineWidth = 1.5;
        ctx.beginPath();
        ctx.arc(cx, cy, 6, 0, Math.PI * 2);
        ctx.stroke();
        ctx.strokeStyle = "rgba(0,0,0,.4)";
        ctx.lineWidth = 0.8;
        ctx.beginPath();
        ctx.arc(cx, cy, 6, 0, Math.PI * 2);
        ctx.stroke();
      }

      function drawHueCanvas(c) {
        if (!c) return;
        const ctx = c.getContext("2d"),
          w = c.width,
          h = c.height;
        const g = ctx.createLinearGradient(0, 0, 0, h);
        for (let i = 0; i <= 6; i++)
          g.addColorStop(i / 6, `hsl(${i * 60},100%,50%)`);
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, w, h);
        const cy = (pickerH / 360) * h;
        ctx.fillStyle = "white";
        ctx.fillRect(0, cy - 2, w, 4);
        ctx.fillStyle = "rgba(0,0,0,.4)";
        ctx.fillRect(0, cy - 1, w, 2);
      }

      function refreshPickerUI() {
        const sv = document.getElementById("sv-canvas");
        const hue = document.getElementById("hue-canvas");
        const prev = document.getElementById("color-preview");
        const hexIn = document.getElementById("hex-input");
        const swatches = document.querySelectorAll(".swatch");
        if (sv) drawSVCanvas(sv);
        if (hue) drawHueCanvas(hue);
        if (prev) prev.style.background = color;
        if (hexIn) hexIn.value = color;
        swatches.forEach((s) =>
          s.classList.toggle("active", s.dataset.c === color),
        );
      }

      // ═══════════════════════════════════════════════════════
      //  SELECTION
      // ═══════════════════════════════════════════════════════
      function clearSelection() {
        selection = null;
        selecting = false;
        selStart = null;
        if (tool === "select") renderProps(); // update info
      }

      function drawSelectionOnCursor(ctx) {
        if (!selection || !selection.w || !selection.h) return;
        ctx.save();
        ctx.lineWidth = 1;
        const { x, y, w, h } = selection;
        // double stroke: black below, white above (marching ants effect)
        ctx.setLineDash([4, 4]);
        ctx.lineDashOffset = -marchOffset;
        ctx.strokeStyle = "rgba(0,0,0,.7)";
        ctx.strokeRect(x + 0.5, y + 0.5, w, h);
        ctx.lineDashOffset = -(marchOffset + 4);
        ctx.strokeStyle = "rgba(255,255,255,.9)";
        ctx.strokeRect(x + 0.5, y + 0.5, w, h);
        ctx.setLineDash([]);
        ctx.restore();
      }

      function applySelectionClip(ctx) {
        if (!selection) return false;
        ctx.save();
        ctx.beginPath();
        ctx.rect(selection.x, selection.y, selection.w, selection.h);
        ctx.clip();
        return true;
      }

      // ═══════════════════════════════════════════════════════
      //  TEXT OBJECTS
      // ═══════════════════════════════════════════════════════
      function drawTextObjects(ctx) {
        for (const t of textObjects) {
          ctx.save();
          ctx.font = `${t.bold ? "bold " : ""} ${t.size}px "${t.font}"`;
          ctx.textBaseline = "top";
          const lineH = t.size * 1.3;
          t.lines.forEach((line, i) => {
            const ly = t.y + i * lineH;
            if (t.useStroke) {
              ctx.strokeStyle = t.strokeColor;
              ctx.lineWidth = t.strokeWidth;
              ctx.lineJoin = "round";
              ctx.strokeText(line, t.x, ly);
            }
            ctx.fillStyle = t.color;
            ctx.fillText(line, t.x, ly);
          });
          ctx.restore();
        }
      }

      function getTextBounds(t) {
        displayCtx.font = `${t.bold ? "bold " : ""} ${t.size}px "${t.font}"`;
        const maxW = Math.max(
          ...t.lines.map((l) => displayCtx.measureText(l).width || t.size),
        );
        return { x: t.x, y: t.y, w: maxW, h: t.lines.length * t.size * 1.3 };
      }

      function hitTestText(cx, cy) {
        for (let i = textObjects.length - 1; i >= 0; i--) {
          const b = getTextBounds(textObjects[i]);
          const pad = 6;
          if (
            cx >= b.x - pad &&
            cx <= b.x + b.w + pad &&
            cy >= b.y - pad &&
            cy <= b.y + b.h + pad
          )
            return textObjects[i].id;
        }
        return null;
      }

      function drawTextSelection(ctx) {
        if (selectedTextId === null) return;
        const t = textObjects.find((o) => o.id === selectedTextId);
        if (!t) return;
        const b = getTextBounds(t);
        const pad = 4;
        ctx.save();
        ctx.strokeStyle = "rgba(91,141,238,.8)";
        ctx.lineWidth = 1;
        ctx.setLineDash([3, 3]);
        ctx.strokeRect(b.x - pad, b.y - pad, b.w + pad * 2, b.h + pad * 2);
        ctx.setLineDash([]);
        ctx.restore();
      }

      function createTextAt(cx, cy) {
        const t = {
          id: nextTextId++,
          x: cx,
          y: cy,
          lines: [""],
          font: textProps.font,
          size: textProps.size,
          bold: textProps.bold,
          color: textProps.color,
          useStroke: textProps.useStroke,
          strokeColor: textProps.strokeColor,
          strokeWidth: textProps.strokeWidth,
        };
        textObjects.push(t);
        selectedTextId = t.id;
        showTA(t, true);
        composite();
        renderProps();
      }

      function showTA(t, isNew) {
        if (activeTA) {
          activeTA.remove();
          activeTA = null;
        }
        const sx = panX + t.x * zoom,
          sy = panY + t.y * zoom;
        const ta = document.createElement("textarea");
        ta.value = t.lines.join("\n");
        ta.className = "text-ta";
        ta.style.left = sx + "px";
        ta.style.top = sy + "px";
        ta.style.fontFamily = `"${t.font}"`;
        ta.style.fontSize = t.size * zoom + "px";
        ta.style.fontWeight = t.bold ? "bold" : "normal";
        ta.style.minWidth = Math.max(80, 120 * zoom) + "px";
        ta.style.minHeight = t.size * zoom * 1.3 + "px";
        textInputWrap.appendChild(ta);
        ta.focus();
        if (!isNew) {
          ta.select();
        }
        activeTA = ta;

        ta.addEventListener("input", () => {
          const idx = textObjects.findIndex((o) => o.id === t.id);
          if (idx >= 0) {
            textObjects[idx].lines = ta.value.split("\n") || [""];
            composite();
          }
          ta.style.height = "auto";
          ta.style.height = ta.scrollHeight + "px";
        });
        ta.addEventListener("blur", () => {
          setTimeout(finalizeTA, 80);
        });
        ta.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            e.preventDefault();
            cancelTA(t.id);
          }
        });
      }

      function finalizeTA() {
        if (!activeTA) return;
        // clean empty objects
        const idx = textObjects.findIndex((o) => o.id === selectedTextId);
        if (idx >= 0 && textObjects[idx].lines.join("").trim() === "")
          textObjects.splice(idx, 1);
        activeTA.remove();
        activeTA = null;
        composite();
        redrawCursor();
      }

      function cancelTA(id) {
        const idx = textObjects.findIndex((o) => o.id === id);
        if (idx >= 0) textObjects.splice(idx, 1);
        if (activeTA) {
          activeTA.remove();
          activeTA = null;
        }
        selectedTextId = null;
        composite();
        redrawCursor();
      }

      function deleteSelectedText() {
        if (selectedTextId === null) return;
        const idx = textObjects.findIndex((o) => o.id === selectedTextId);
        if (idx >= 0) textObjects.splice(idx, 1);
        selectedTextId = null;
        composite();
        redrawCursor();
        renderProps();
        toast("Texto eliminado");
      }

      // ═══════════════════════════════════════════════════════
      //  EYEDROPPER
      // ═══════════════════════════════════════════════════════
      function sampleColorAt(x, y) {
        const px = Math.max(0, Math.min(imgW - 1, x)),
          py = Math.max(0, Math.min(imgH - 1, y));
        const d = displayCtx.getImageData(px, py, 1, 1).data;
        const hex =
          "#" +
          [d[0], d[1], d[2]]
            .map((v) => v.toString(16).padStart(2, "0"))
            .join("");
        setColor(hex);
        toast("Color tomado: " + hex);
        refreshPickerUI();
      }

      // ═══════════════════════════════════════════════════════
      //  LAYERS PANEL
      // ═══════════════════════════════════════════════════════
      function renderLayers() {
        const list = document.getElementById("layers-list");
        list.innerHTML = "";
        [...layers].reverse().forEach((layer, ri) => {
          const idx = layers.length - 1 - ri,
            isActive = idx === activeLayerIndex;
          const wrap2 = document.createElement("div");
          wrap2.className = "layer-wrap";
          const row = document.createElement("div");
          row.className = "layer-row" + (isActive ? " active-layer" : "");
          row.innerHTML = `
      <button class="layer-eye" onclick="toggleVis(event,${idx})">${layer.visible ? "👁️" : "🚫"}</button>
      <div class="layer-dot" style="background:${layer.dotColor}"></div>
      <div class="layer-name" ondblclick="startRename(${idx},this)">${layer.name}${layer.locked ? " 🔒" : ""}</div>
      <span class="layer-pct">${Math.round(layer.opacity * 100)}%</span>
      <div class="layer-acts">
        <button class="lico" onclick="moveLayer(${idx},-1)" ${idx === layers.length - 1 ? "disabled" : ""}>↑</button>
        <button class="lico" onclick="moveLayer(${idx},1)" ${idx === 0 ? "disabled" : ""}>↓</button>
        <button class="lico del" onclick="deleteLayer(${idx})" ${layers.length <= 1 || layer.locked ? "disabled" : ""}>✕</button>
      </div>`;
          const opRow = document.createElement("div");
          opRow.className = "layer-oprow";
          opRow.innerHTML = `Opacidad<input type="range" style="flex:1;margin-left:6px" min="0" max="100"
      value="${Math.round(layer.opacity * 100)}" oninput="setLayerOp(${idx},this.value)">`;
          row.addEventListener("click", (e) => {
            if (e.target.closest("button")) return;
            if (e.altKey) soloLayer(idx);
            else setActiveLayer(idx);
          });
          wrap2.appendChild(row);
          wrap2.appendChild(opRow);
          list.appendChild(wrap2);
        });
      }
      function toggleVis(e, idx) {
        e.stopPropagation();
        layers[idx].visible = !layers[idx].visible;
        composite();
        renderLayers();
      }
      function setActiveLayer(idx) {
        activeLayerIndex = idx;
        renderLayers();
      }
      function setLayerOp(idx, v) {
        layers[idx].opacity = v / 100;
        composite();
        renderLayers();
      }
      function soloLayer(idx) {
        const allV = layers.every((l, i) => (i === idx ? true : !l.visible));
        layers.forEach((l, i) => {
          l.visible = allV ? true : i === idx;
        });
        composite();
        renderLayers();
        toast(allV ? "Todas visibles" : `Solo "${layers[idx].name}"`);
      }
      function addLayer() {
        if (!imageLoaded) {
          toast("Cargá una imagen primero");
          return;
        }
        const C = ["#e8c547", "#e85b8a", "#e87a5b", "#b85bee", "#5beee8"];
        const l = mkLayer(
          "Capa " + nextLayerId,
          C[(nextLayerId - 1) % C.length],
        );
        l.canvas = mkLayerCanvas(imgW, imgH);
        layers.push(l);
        activeLayerIndex = layers.length - 1;
        renderLayers();
        toast("Capa creada");
      }
      function deleteLayer(idx) {
        if (layers.length <= 1 || layers[idx].locked) return;
        if (!confirm(`¿Eliminar "${layers[idx].name}"?`)) return;
        layers.splice(idx, 1);
        activeLayerIndex = Math.min(activeLayerIndex, layers.length - 1);
        composite();
        renderLayers();
        toast("Capa eliminada");
      }
      function moveLayer(idx, dir) {
        const t2 = idx - dir;
        if (t2 < 0 || t2 >= layers.length) return;
        [layers[idx], layers[t2]] = [layers[t2], layers[idx]];
        if (activeLayerIndex === idx) activeLayerIndex = t2;
        else if (activeLayerIndex === t2) activeLayerIndex = idx;
        composite();
        renderLayers();
      }
      function startRename(idx, el) {
        if (layers[idx].locked) return;
        const inp = document.createElement("input");
        inp.className = "layer-name-input";
        inp.value = layers[idx].name;
        el.replaceWith(inp);
        inp.focus();
        inp.select();
        const done = () => {
          layers[idx].name = inp.value || layers[idx].name;
          renderLayers();
        };
        inp.addEventListener("blur", done);
        inp.addEventListener("keydown", (e) => {
          if (e.key === "Enter") inp.blur();
          if (e.key === "Escape") {
            inp.value = layers[idx].name;
            inp.blur();
          }
        });
      }

      // ═══════════════════════════════════════════════════════
      //  HISTORY PANEL
      // ═══════════════════════════════════════════════════════
      function renderHistory() {
        const list = document.getElementById("history-list");
        if (!hist.length) {
          list.innerHTML = '<div class="no-hist">Sin acciones aún</div>';
          return;
        }
        list.innerHTML = [...hist]
          .reverse()
          .map((it, ri) => {
            const i = hist.length - 1 - ri,
              cls = i === histIdx ? "cur" : i > histIdx ? "fut" : "";
            return `<div class="hitem ${cls}"><span class="hico">${it.icon}</span><span class="hlbl">${it.label}</span><span class="hlyr">${it.layerName}</span></div>`;
          })
          .join("");
      }

      // ═══════════════════════════════════════════════════════
      //  PANEL TABS
      // ═══════════════════════════════════════════════════════
      function switchTab(name) {
        const names = ["props", "layers", "history"];
        document
          .querySelectorAll(".ptab")
          .forEach((t, i) => t.classList.toggle("active", names[i] === name));
        document
          .querySelectorAll(".tab-pane")
          .forEach((p, i) =>
            p.classList.toggle(
              "active",
              ["tab-props", "tab-layers", "tab-history"][i] === "tab-" + name,
            ),
          );
      }

      // ═══════════════════════════════════════════════════════
      //  ZOOM / PAN
      // ═══════════════════════════════════════════════════════
      function applyTransform() {
        container.style.transform = `translate(${panX}px,${panY}px) scale(${zoom})`;
        document.getElementById("zoom-display").textContent =
          Math.round(zoom * 100) + "%";
        // reposition text input if visible
        if (activeTA && selectedTextId !== null) {
          const t = textObjects.find((o) => o.id === selectedTextId);
          if (t) {
            activeTA.style.left = panX + t.x * zoom + "px";
            activeTA.style.top = panY + t.y * zoom + "px";
            activeTA.style.fontSize = t.size * zoom + "px";
          }
        }
      }
      function zoomAt(cx, cy, f) {
        const nz = Math.min(Math.max(zoom * f, 0.04), 40),
          s = nz / zoom;
        panX = cx - s * (cx - panX);
        panY = cy - s * (cy - panY);
        zoom = nz;
        applyTransform();
      }
      function zoomIn() {
        const r = wrap.getBoundingClientRect();
        zoomAt(r.width / 2, r.height / 2, 1.25);
      }
      function zoomOut() {
        const r = wrap.getBoundingClientRect();
        zoomAt(r.width / 2, r.height / 2, 0.8);
      }
      function zoomFit() {
        if (!imageLoaded) return;
        const r = wrap.getBoundingClientRect();
        zoom = Math.min((r.width - 40) / imgW, (r.height - 40) / imgH);
        panX = (r.width - imgW * zoom) / 2;
        panY = (r.height - imgH * zoom) / 2;
        applyTransform();
      }
      wrap.addEventListener(
        "wheel",
        (e) => {
          e.preventDefault();
          const r = wrap.getBoundingClientRect();
          zoomAt(
            e.clientX - r.left,
            e.clientY - r.top,
            e.deltaY < 0 ? 1.1 : 0.9,
          );
        },
        { passive: false },
      );

      // ═══════════════════════════════════════════════════════
      //  COORDINATE CONVERSION  (invert CSS transform)
      // ═══════════════════════════════════════════════════════
      function toCanvas(e) {
        const r = wrap.getBoundingClientRect();
        return {
          x: Math.round((e.clientX - r.left - panX) / zoom),
          y: Math.round((e.clientY - r.top - panY) / zoom),
        };
      }

      // ═══════════════════════════════════════════════════════
      //  DRAWING  (fixed 1-2px brush)
      // ═══════════════════════════════════════════════════════
      function drawStroke(x, y, fx, fy) {
        const lctx = getActiveCtx();
        if (!lctx) return;
        lctx.save();
        const clipped = applySelectionClip(lctx);
        lctx.globalAlpha = brushOpacity;
        const c = tool === "eraser" ? "#ffffff" : color;
        lctx.fillStyle = c;
        lctx.strokeStyle = c;

        if (brushSize <= 2) {
          // pixel-perfect for small sizes: walk the line manually
          const dx = x - fx,
            dy = y - fy;
          const steps = Math.max(1, Math.ceil(Math.sqrt(dx * dx + dy * dy)));
          for (let i = 0; i <= steps; i++) {
            const t = i / steps;
            const px = Math.round(fx + dx * t),
              py = Math.round(fy + dy * t);
            lctx.fillRect(px, py, brushSize, brushSize);
          }
        } else {
          lctx.lineWidth = brushSize;
          lctx.lineCap = brushShape === "round" ? "round" : "square";
          lctx.lineJoin = brushShape === "round" ? "round" : "miter";
          lctx.beginPath();
          lctx.moveTo(fx, fy);
          lctx.lineTo(x, y);
          lctx.stroke();
          if (brushShape === "round") {
            lctx.beginPath();
            lctx.arc(x, y, brushSize / 2, 0, Math.PI * 2);
            lctx.fill();
          } else
            lctx.fillRect(
              x - brushSize / 2,
              y - brushSize / 2,
              brushSize,
              brushSize,
            );
        }
        if (clipped) lctx.restore();
        else lctx.restore();
        composite();
      }

      // ── FLOOD FILL ──
      function hexRGB(hex) {
        return [
          parseInt(hex.slice(1, 3), 16),
          parseInt(hex.slice(3, 5), 16),
          parseInt(hex.slice(5, 7), 16),
        ];
      }
      function floodFill(sx, sy) {
        const lctx = getActiveCtx();
        if (!lctx) return;
        const w = imgW,
          h = imgH;
        const src = lctx.getImageData(0, 0, w, h),
          dst = lctx.getImageData(0, 0, w, h);
        const sd = src.data,
          dd = dst.data;
        const i0 = (sy * w + sx) * 4;
        const tr = sd[i0],
          tg = sd[i0 + 1],
          tb = sd[i0 + 2];
        const [fr, fg, fb] = hexRGB(color);
        if (Math.abs(tr - fr) + Math.abs(tg - fg) + Math.abs(tb - fb) < 6)
          return;
        const tol = fillTol * 3;
        const visited = new Uint8Array(w * h);
        const stack = [sx + sy * w];

        // optionally restrict to selection
        const hasClip = !!selection;
        const sx0 = hasClip ? selection.x : 0,
          sy0 = hasClip ? selection.y : 0;
        const sx1 = hasClip ? selection.x + selection.w : w,
          sy1 = hasClip ? selection.y + selection.h : h;

        while (stack.length) {
          const pos = stack.pop();
          if (visited[pos]) continue;
          const px = pos % w,
            py = (pos / w) | 0;
          if (px < sx0 || px >= sx1 || py < sy0 || py >= sy1) continue;
          const pi = pos * 4;
          if (
            Math.abs(sd[pi] - tr) +
              Math.abs(sd[pi + 1] - tg) +
              Math.abs(sd[pi + 2] - tb) >
            tol
          )
            continue;
          visited[pos] = 1;
          dd[pi] = fr;
          dd[pi + 1] = fg;
          dd[pi + 2] = fb;
          dd[pi + 3] = 255;
          if (px + 1 < w) stack.push(pos + 1);
          if (px - 1 >= 0) stack.push(pos - 1);
          if (py + 1 < h) stack.push(pos + w);
          if (py - 1 >= 0) stack.push(pos - w);
        }
        lctx.putImageData(dst, 0, 0);
        composite();
      }

      // ══════════════════════════════════════════════════════
      //  CURSOR + RAF LOOP
      // ══════════════════════════════════════════════════════
      function redrawCursor() {
        if (!imageLoaded) return;
        cursorCtx.clearRect(0, 0, imgW, imgH);
        drawSelectionOnCursor(cursorCtx);
        drawTextSelection(cursorCtx);
        if (["brush", "eraser"].includes(tool)) {
          const { x, y } = lastMouse,
            r = brushSize / 2;
          cursorCtx.save();
          cursorCtx.strokeStyle = "rgba(255,255,255,.85)";
          cursorCtx.lineWidth = 1;
          if (brushSize <= 2) {
            cursorCtx.strokeRect(x - 0.5, y - 0.5, brushSize, brushSize);
          } else if (brushShape === "round") {
            cursorCtx.beginPath();
            cursorCtx.arc(x, y, r, 0, Math.PI * 2);
            cursorCtx.stroke();
          } else {
            cursorCtx.strokeRect(x - r, y - r, brushSize, brushSize);
          }
          cursorCtx.fillStyle = "rgba(255,255,255,.65)";
          cursorCtx.beginPath();
          cursorCtx.arc(x, y, 1.2, 0, Math.PI * 2);
          cursorCtx.fill();
          cursorCtx.restore();
        }
      }

      // Marching ants RAF
      (function raf() {
        marchOffset = (marchOffset + 0.35) % 8;
        redrawCursor();
        requestAnimationFrame(raf);
      })();

      // ═══════════════════════════════════════════════════════
      //  MOUSE EVENTS
      // ═══════════════════════════════════════════════════════
      wrap.addEventListener("mousedown", (e) => {
        if (!imageLoaded) return;
        e.preventDefault();

        // Space pan
        if (spaceDown || tool === "pan") {
          panSX = e.clientX;
          panSY = e.clientY;
          panOX = panX;
          panOY = panY;
          wrap.style.cursor = "grabbing";
          return;
        }

        const pos = toCanvas(e);

        // Alt+click = eyedropper always
        if (e.altKey && imageLoaded) {
          sampleColorAt(pos.x, pos.y);
          return;
        }

        if (tool === "zoomtool") {
          const r = wrap.getBoundingClientRect();
          zoomAt(
            e.clientX - r.left,
            e.clientY - r.top,
            e.shiftKey ? 0.8 : 1.25,
          );
          return;
        }
        if (tool === "eyedropper") {
          sampleColorAt(pos.x, pos.y);
          return;
        }

        if (tool === "select") {
          clearSelection();
          selecting = true;
          selStart = { x: pos.x, y: pos.y };
          selection = { x: pos.x, y: pos.y, w: 0, h: 0 };
          return;
        }

        if (tool === "text") {
          const hitId = hitTestText(pos.x, pos.y);
          if (hitId !== null) {
            if (hitId === selectedTextId && !activeTA) {
              // double-ish click on already selected: open editor
              const t = textObjects.find((o) => o.id === hitId);
              if (t) showTA(t, false);
            } else {
              if (activeTA) finalizeTA();
              selectedTextId = hitId;
              const t = textObjects.find((o) => o.id === hitId);
              if (t) {
                textDragging = true;
                textDragOffset = { x: pos.x - t.x, y: pos.y - t.y };
              }
            }
          } else {
            if (activeTA) finalizeTA();
            selectedTextId = null;
            createTextAt(pos.x, pos.y);
          }
          renderProps();
          return;
        }

        if (pos.x < 0 || pos.y < 0 || pos.x >= imgW || pos.y >= imgH) return;
        if (layers[activeLayerIndex]?.locked) {
          toast("Capa bloqueada 🔒");
          return;
        }

        if (tool === "fill") {
          const before = captureLayer(activeLayerIndex);
          floodFill(pos.x, pos.y);
          pushHist(
            "Relleno",
            "🪣",
            activeLayerIndex,
            before,
            captureLayer(activeLayerIndex),
          );
          return;
        }
        if (tool === "brush" || tool === "eraser") {
          pendingBefore = captureLayer(activeLayerIndex);
          painting = true;
          lastX = pos.x;
          lastY = pos.y;
          drawStroke(pos.x, pos.y, pos.x, pos.y);
        }
      });

      wrap.addEventListener("mousemove", (e) => {
        const pos = toCanvas(e);
        lastMouse = { x: pos.x, y: pos.y };
        document.getElementById("coords").textContent =
          `x: ${pos.x}  y: ${pos.y}`;

        if ((spaceDown || tool === "pan") && e.buttons === 1) {
          panX = panOX + e.clientX - panSX;
          panY = panOY + e.clientY - panSY;
          applyTransform();
          return;
        }
        if (tool === "select" && selecting && e.buttons === 1) {
          const x = Math.min(selStart.x, pos.x),
            y = Math.min(selStart.y, pos.y);
          const w = Math.abs(pos.x - selStart.x),
            h = Math.abs(pos.y - selStart.y);
          selection = { x, y, w, h };
          return;
        }
        if (tool === "text" && textDragging && e.buttons === 1) {
          const t = textObjects.find((o) => o.id === selectedTextId);
          if (t) {
            t.x = pos.x - textDragOffset.x;
            t.y = pos.y - textDragOffset.y;
            composite();
          }
          return;
        }
        if (
          painting &&
          e.buttons === 1 &&
          (tool === "brush" || tool === "eraser")
        ) {
          drawStroke(pos.x, pos.y, lastX, lastY);
          lastX = pos.x;
          lastY = pos.y;
        }
      });

      wrap.addEventListener("mouseup", (e) => {
        if (painting && pendingBefore) {
          const lbl = tool === "brush" ? "Pincelada" : "Borrado";
          const ico = tool === "brush" ? "✏️" : "🧹";
          pushHist(
            lbl,
            ico,
            activeLayerIndex,
            pendingBefore,
            captureLayer(activeLayerIndex),
          );
          pendingBefore = null;
        }
        painting = false;
        textDragging = false;
        if (selecting) {
          selecting = false;
          if (selection && (selection.w < 3 || selection.h < 3))
            clearSelection();
          else if (tool === "select") renderProps();
        }
        if (tool === "pan") wrap.style.cursor = "grab";
      });

      wrap.addEventListener("dblclick", (e) => {
        if (tool !== "text") return;
        const pos = toCanvas(e);
        const hitId = hitTestText(pos.x, pos.y);
        if (hitId !== null) {
          const t = textObjects.find((o) => o.id === hitId);
          selectedTextId = hitId;
          if (t) showTA(t, false);
        }
      });

      wrap.addEventListener("mouseleave", () => {
        painting = false;
      });

      // ── KEYBOARD ──
      document.addEventListener("keydown", (e) => {
        if (e.code === "Space" && e.target === document.body) {
          e.preventDefault();
          spaceDown = true;
          panOX = panX;
          panOY = panY;
          panSX = 0;
          panSY = 0;
          wrap.style.cursor = "grab";
        }
        if (
          e.target.tagName === "INPUT" ||
          e.target.tagName === "TEXTAREA" ||
          e.target.tagName === "SELECT"
        )
          return;
        const k = e.key;
        if (!e.ctrlKey) {
          if (k === "b" || k === "B") setTool("brush");
          if (k === "e" || k === "E") setTool("eraser");
          if (k === "f" || k === "F") setTool("fill");
          if (k === "s" || k === "S") setTool("select");
          if (k === "t" || k === "T") setTool("text");
          if (k === "i" || k === "I") setTool("eyedropper");
          if (k === "v" || k === "V") setTool("pan");
          if (k === "z" || k === "Z") setTool("zoomtool");
          if (k === "[") {
            brushSize = Math.max(1, brushSize - 5);
            renderProps();
          }
          if (k === "]") {
            brushSize = Math.min(200, brushSize + 5);
            renderProps();
          }
          if (k === "Delete" && selectedTextId !== null) deleteSelectedText();
        }
        if (e.ctrlKey) {
          if (k === "z") {
            e.preventDefault();
            undo();
          }
          if (k === "y") {
            e.preventDefault();
            redo();
          }
          if (k === "d") {
            e.preventDefault();
            clearSelection();
            redrawCursor();
          }
        }
      });
      document.addEventListener("keyup", (e) => {
        if (e.code === "Space") {
          spaceDown = false;
          wrap.style.cursor = tool === "pan" ? "grab" : "crosshair";
        }
      });

      // ═══════════════════════════════════════════════════════
      //  IMAGE LOADING
      // ═══════════════════════════════════════════════════════
      function loadImage(file) {
        if (!file || !file.type.startsWith("image/")) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
          const img = new Image();
          img.onload = () => {
            const w = img.width,
              h = img.height;
            displayCanvas.width = w;
            displayCanvas.height = h;
            cursorCanvas.width = w;
            cursorCanvas.height = h;
            displayCtx.imageSmoothingEnabled = false;
            cursorCtx.imageSmoothingEnabled = false;
            initLayers(w, h);
            getLayerCtx(0).drawImage(img, 0, 0);
            textObjects = [];
            selectedTextId = null;
            clearSelection();
            composite();
            imageLoaded = true;
            document.getElementById("drop-overlay").classList.add("hidden");
            document.getElementById("page-info").textContent = `${w} × ${h}px`;
            hist.length = 0;
            histIdx = -1;
            renderHistory();
            updateURBtns();
            renderLayers();
            setTimeout(zoomFit, 50);
            toast("✓ Imagen cargada");
          };
          img.src = ev.target.result;
        };
        reader.readAsDataURL(file);
      }
      document
        .getElementById("fi")
        .addEventListener("change", (e) => loadImage(e.target.files[0]));
      wrap.addEventListener("dragover", (e) => {
        e.preventDefault();
        wrap.classList.add("drag-over");
      });
      wrap.addEventListener("dragleave", () =>
        wrap.classList.remove("drag-over"),
      );
      wrap.addEventListener("drop", (e) => {
        e.preventDefault();
        wrap.classList.remove("drag-over");
        loadImage(e.dataTransfer.files[0]);
      });

      // ═══════════════════════════════════════════════════════
      //  SAVE / LOAD PROJECT
      // ═══════════════════════════════════════════════════════
      async function saveProject() {
        if (!imageLoaded) {
          toast("Cargá una imagen primero");
          return;
        }
        toast("Guardando...");
        const layerData = layers.map((l) => ({
          name: l.name,
          dotColor: l.dotColor,
          locked: l.locked,
          visible: l.visible,
          opacity: l.opacity,
          data: l.canvas ? l.canvas.toDataURL("image/png") : null,
        }));
        const project = {
          version: 1,
          width: imgW,
          height: imgH,
          layers: layerData,
          textObjects: textObjects.map((t) => ({ ...t })),
        };
        const blob = new Blob([JSON.stringify(project)], {
          type: "application/json",
        });
        const a = document.createElement("a");
        a.href = URL.createObjectURL(blob);
        a.download = "proyecto.scantool";
        a.click();
        toast("✓ Proyecto guardado");
      }

      async function loadProject(file) {
        if (!file) return;
        const text = await file.text();
        let project;
        try {
          project = JSON.parse(text);
        } catch {
          toast("Archivo inválido");
          return;
        }
        if (!project.version || !project.layers) {
          toast("Formato inválido");
          return;
        }

        const w = project.width,
          h = project.height;
        displayCanvas.width = w;
        displayCanvas.height = h;
        cursorCanvas.width = w;
        cursorCanvas.height = h;
        displayCtx.imageSmoothingEnabled = false;
        cursorCtx.imageSmoothingEnabled = false;
        imgW = w;
        imgH = h;
        nextLayerId = 1;

        layers = project.layers.map((ld) => {
          const l = mkLayer(ld.name, ld.dotColor, ld.locked);
          l.visible = ld.visible;
          l.opacity = ld.opacity;
          l.canvas = mkLayerCanvas(w, h);
          return l;
        });
        activeLayerIndex = Math.min(1, layers.length - 1);

        // load layer images async
        await Promise.all(
          project.layers.map(
            (ld, i) =>
              new Promise((res) => {
                if (!ld.data) {
                  res();
                  return;
                }
                const img = new Image();
                img.onload = () => {
                  getLayerCtx(i).drawImage(img, 0, 0);
                  res();
                };
                img.src = ld.data;
              }),
          ),
        );

        textObjects = (project.textObjects || []).map((t) => ({ ...t }));
        selectedTextId = null;
        clearSelection();
        imageLoaded = true;
        document.getElementById("drop-overlay").classList.add("hidden");
        document.getElementById("page-info").textContent = `${w} × ${h}px`;
        hist.length = 0;
        histIdx = -1;
        composite();
        renderHistory();
        updateURBtns();
        renderLayers();
        setTimeout(zoomFit, 50);
        toast("✓ Proyecto cargado");
      }
      document
        .getElementById("load-fi")
        .addEventListener("change", (e) => loadProject(e.target.files[0]));

      // ═══════════════════════════════════════════════════════
      //  EXPORT PNG
      // ═══════════════════════════════════════════════════════
      function exportPNG() {
        if (!imageLoaded) {
          toast("Cargá una imagen primero");
          return;
        }
        const tmp = mkLayerCanvas(imgW, imgH);
        const tctx = tmp.getContext("2d");
        tctx.imageSmoothingEnabled = false;
        for (const l of layers) {
          if (l.visible && l.canvas) {
            tctx.globalAlpha = l.opacity;
            tctx.drawImage(l.canvas, 0, 0);
          }
        }
        tctx.globalAlpha = 1;
        drawTextObjects(tctx); // include text in export
        const a = document.createElement("a");
        a.href = tmp.toDataURL("image/png");
        a.download = "pagina_limpia.png";
        a.click();
        toast("✓ Exportado como PNG");
      }

      // ═══════════════════════════════════════════════════════
      //  TOAST
      // ═══════════════════════════════════════════════════════
      let toastT;
      function toast(msg) {
        const el = document.getElementById("toast");
        el.textContent = msg;
        el.classList.add("show");
        clearTimeout(toastT);
        toastT = setTimeout(() => el.classList.remove("show"), 2400);
      }

      // INIT
      setTool("brush");
      renderProps();
      renderHistory();
      renderLayers();
      applyTransform();
    </script>
  </body>
</html>
